APP_NAME="RESOL Comandas"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -------------------------------------------------------------------
# Base de datos de RESOL (no correr migraciones)
# -------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=resol
DB_USERNAME=root
DB_PASSWORD=

# -------------------------------------------------------------------
# Configuración regional
# -------------------------------------------------------------------
CURRENCY_SYMBOL=L

# -------------------------------------------------------------------
# Impresoras
# -------------------------------------------------------------------
# Nombre exacto de la impresora de barra en "Dispositivos e impresoras"
PRINTER_BARRA=EPSON-TMU220
# IP de la impresora de cocina (red). Dejar vacío para redirigir a BARRA
PRINTER_COCINA_IP=
PRINTER_COCINA_PORT=9100

# -------------------------------------------------------------------
# Imágenes de RESOL
# Ruta a la carpeta de imágenes de categorías de RESOL (usar /)
# -------------------------------------------------------------------
RESOL_IMG_PATH="C:/Program Files (x86)/TechSupport/Sistema de Restaurante/resources/img/categorias"

# -------------------------------------------------------------------
# WiFi del local (para el cartelito imprimible)
# -------------------------------------------------------------------
WIFI_SSID="NombreDelWiFi"
WIFI_PASSWORD=""

# -------------------------------------------------------------------
# Unifi Controller (para portal cautivo — opcional)
# -------------------------------------------------------------------
UNIFI_HOST=192.168.1.1
UNIFI_PORT=8443
UNIFI_USER=admin
UNIFI_PASSWORD=
UNIFI_SITE=default

# -------------------------------------------------------------------
# Laravel internals (no modificar en producción salvo SESSION/CACHE)
# -------------------------------------------------------------------
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"
